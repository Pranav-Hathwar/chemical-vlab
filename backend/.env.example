# ─────────────────────────────────────────────────────────────────────────────
#  MFR Lab Backend — environment template.
#
#  Copy this file to `.env` (in the same `backend/` folder) and fill in values:
#      cp .env.example .env           # macOS/Linux
#      Copy-Item .env.example .env    # Windows PowerShell
#
#  Every variable below is read by the code (see src/config, src/index.js,
#  src/services, src/middleware, and prisma/schema.prisma). `.env` is gitignored
#  — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
# PORT      : port the API listens on. Hosts (Railway/Render) inject this; for
#             local dev use 4000 (the Flutter app defaults to localhost:4000).
# NODE_ENV  : "development" enables verbose Prisma warn logs; use "production"
#             when deploying (quieter logs).
PORT=4000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of EXACT browser origins allowed to call the API (no
# wildcard). Flutter web must be served from one of these. Run the web app with
# `flutter run -d chrome --web-port=8087` so its origin matches the first entry.
# Add your deployed frontend origin here too (e.g. https://your-app.web.app).
CORS_ORIGINS=http://localhost:8087,http://127.0.0.1:8087,http://localhost:3000

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Connection string used by Prisma. Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
# Create the DB first (`CREATE DATABASE mfr_lab;`) or let `prisma migrate dev`
# create it if your user has rights. URL-encode special chars in the password.
DATABASE_URL="postgresql://postgres:2092@localhost:5432/mfr_lab?schema=public"

# ── JWT ──────────────────────────────────────────────────────────────────────
# Signing secrets for access + refresh tokens. Generate a strong unique value
# for EACH (do not reuse one for both):
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=fOp1xubZbe8wZ3HGpVv_1D3ZDBMFcOGf_GapDSrgLvb2Drdo6UjdecZediS4fC3q
JWT_REFRESH_SECRET=QfeJK2lR_TndR0pewZHdQ41-HYeKXj-mX1rC0lxxxR8yDx6DRNomFsSAHkQSY0jd
# Token lifetimes (zeit/ms format). Defaults are sensible; leave as-is normally.
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Hidden-k encryption ──────────────────────────────────────────────────────
# Master secret for AES-256-GCM encryption of the hidden rate constant `k`.
# Per-session key = HMAC-SHA256(studentId + sessionId, ENCRYPTION_SECRET).
# Generate with the same command as the JWT secrets above.
ENCRYPTION_SECRET=-ugzvu7Gls5BWX_ICQhmMAc9-mCEJxo9RW606KpXeYptwRAtDnCiKqn1RQXFbADE

# ── Roles ────────────────────────────────────────────────────────────────────
# Comma-separated emails that are granted the `admin` role on (re)login. Everyone
# else is a `student`. Put your professor/admin account(s) here.
ADMIN_EMAILS=professor@university.edu

# ── Google OAuth ─────────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID: the "Web application" OAuth client ID from
#   https://console.cloud.google.com/apis/credentials (ends in
#   .apps.googleusercontent.com). Add http://localhost:8087 to that client's
#   "Authorized JavaScript origins". This SAME id must be passed to the Flutter
#   web app: --dart-define=GOOGLE_CLIENT_ID=<id>. Used to verify the token's
#   audience. (Client IDs are public, not secret.)
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET: NOT used by the current flow (the backend verifies the
#   access/ID token via Google's tokeninfo + userinfo endpoints, no code
#   exchange). Leave blank unless you add a server-side auth-code exchange later.
GOOGLE_CLIENT_SECRET=

# ── Rate limits ──────────────────────────────────────────────────────────────
# Requests per minute. Defaults (if unset) are 5/min on /api/auth and 100/min on
# other API routes — correct for production. Locally, raise them so the smoke
# test and repeated logins aren't throttled (the suite makes >5 auth calls):
AUTH_RATE_MAX=1000
API_RATE_MAX=1000
